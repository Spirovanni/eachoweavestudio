# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-supabase-anon-key

# Optional: Supabase service role key (server-side only, never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI Provider (optional, defaults to "anthropic" if ANTHROPIC_API_KEY is set)
# AI_PROVIDER=anthropic

# API Keys (set in .env.local, never commit real keys)
ANTHROPIC_API_KEY=your-anthropic-api-key             # Required: Format: sk-ant-api03-...
OPENAI_API_KEY=your-openai-api-key                   # Optional: Format: sk-proj-...
PERPLEXITY_API_KEY=your-perplexity-api-key           # Optional: Format: pplx-...
GOOGLE_API_KEY=your-google-api-key                   # Optional: For Google Gemini models
MISTRAL_API_KEY=your-mistral-api-key                 # Optional: For Mistral AI models
XAI_API_KEY=your-xai-api-key                         # Optional: For xAI models
AZURE_OPENAI_API_KEY=your-azure-openai-api-key       # Optional: For Azure OpenAI models
OLLAMA_API_KEY=your-ollama-api-key                   # Optional: For remote Ollama servers

# ElevenLabs (voice/audio)
ELEVENLABS_API_KEY=your-elevenlabs-api-key
NEXT_PUBLIC_ELEVENLABS_API_KEY=your-elevenlabs-api-key
NEXT_PUBLIC_ELEVENLABS_AGENT_ID=your-elevenlabs-agent-id
ELEVENLABS_DEFAULT_VOICE_ID=your-default-voice-id
ELEVENLABS_DEFAULT_MODEL_ID=eleven_turbo_v2
